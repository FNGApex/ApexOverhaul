<configs>
	<!-- Add "Reset Quests" as a direct option on the trader start menu (before "done") -->
	<insertBefore xpath="/dialogs/dialog[@id='trader']/statement[@id='start']/response_entry[@id='done']">
		<response_entry id="resetquests" />
	</insertBefore>

	<!-- Same for the traderTest dialog -->
	<insertBefore xpath="/dialogs/dialog[@id='traderTest']/statement[@id='start']/response_entry[@id='done']">
		<response_entry id="resetquests" />
	</insertBefore>

	<!-- traderTest doesn't have a resetquests response, add one -->
	<append xpath="/dialogs/dialog[@id='traderTest']">
		<response id="resetquests" text="dialog_trader_response_resetquests">
			<action type="Trader" id="reset_quests" />
		</response>
	</append>
</configs>
